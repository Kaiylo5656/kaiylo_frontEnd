ionmodal_exercisevalidationmodal", "callee": "createPortal", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L928"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "map", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L962"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "some", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1025"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "map", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1027"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "(() => {\r\n                                // Build groups: superset members share one dot\r\n                                const groups = [];\r\n                                const seenGroups = new Set();\r\n                                allExercises.forEach((ex, i) => {\r\n                                  if (ex.supersetGroup) {\r\n                                    if (!seenGroups.has(ex.supersetGroup)) {\r\n                                      seenGroups.add(ex.supersetGroup);\r\n                                      const indices = allExercises\r\n                                        .map((e, j) => e.supersetGroup === ex.supersetGroup ? j : -1)\r\n                                        .filter(j => j >= 0);\r\n                                      groups.push(indices);\r\n                                    }\r\n                                  } else {\r\n                                    groups.push([i]);\r\n                                  }\r\n                                });\r\n                                return groups.map((indices, dotIndex) => {\r\n                                  const isCurrent = indices.includes(exerciseIndex);\r\n                                  const isFinalized = indices.every(i => isSpecificExerciseFinalized(i));\r\n                                  return (\r\n                                    <div\r\n                                      key={dotIndex}\r\n                                      className={`w-[5px] h-[5px] rounded-full transition-colors duration-200 ${isCurrent ? 'bg-[#d4845a]' : isFinalized ? 'bg-white/50' : 'bg-white/30'}`}\r\n                                    />\r\n                                  );\r\n                                });\r\n                              })", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1052"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "some", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1153"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "map", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1155"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "(() => {\r\n                                        const repType = sets[0]?.repType || sets[0]?.rep_type || 'reps';\r\n                                        if (repType === 'amrap') {\r\n                                          return 'AMRAP';\r\n                                        } else if (repType === 'hold') {\r\n                                          return 'Hold';\r\n                                        }\r\n                                        return 'Rep.';\r\n                                      })", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1195"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "map", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1227"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "join", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1516"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "filter", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1516"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "map", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1516"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "from", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1529"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "max", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1529"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "map", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1529"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "join", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1796"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingVideos", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1813"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingRpe", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1813"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingVideos", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1815"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingVideos", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1817"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingVideos", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1819"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingRpe", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1822"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingRpe", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1825"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingRpe", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1827"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingRpe", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1829"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "countMissingRpe", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1831"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "map", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1869"}, {"caller_nid": "components_exercisevalidationmodal_exercisevalidationmodal", "callee": "(() => {\r\n        const currentRpe = typeof selectedSetForRpe === 'object' && 'exIdx' in selectedSetForRpe\r\n          ? getRpeForSetOf(selectedSetForRpe.exIdx, selectedSetForRpe.setIndex)\r\n          : getRpeForSet(selectedSetForRpe);\r\n\r\n        // Emp\u00eacher la fermeture par clic sur le backdrop\r\n        const handleBackdropClick = (e) => {\r\n          if (e.target === e.currentTarget) {\r\n            // Ne rien faire - forcer l'utilisateur \u00e0 choisir\r\n            return;\r\n          }\r\n        };\r\n\r\n        return createPortal(\r\n          <div\r\n            className=\"fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-[111] p-4\"\r\n            style={{ backdropFilter: 'blur(4px)', WebkitBackdropFilter: 'blur(4px)' }}\r\n            onClick={handleBackdropClick}\r\n          >\r\n            <div\r\n              className=\"bg-[#1a1a1a] rounded-[25px] w-full max-w-md mx-4 overflow-hidden border border-white/10\"\r\n              onClick={(e) => e.stopPropagation()}\r\n              role=\"dialog\"\r\n              aria-modal=\"true\"\r\n              aria-labelledby=\"rpe-title\"\r\n            >\r\n              {/* Header */}\r\n              <div className=\"flex items-center justify-center px-4 text-center\" style={{ paddingTop: '20px', paddingBottom: '15px' }}>\r\n                <h2 id=\"rpe-title\" className=\"text-[var(--kaiylo-primary-hex)] text-xl font-normal\">\r\n                  RPE\r\n                </h2>\r\n              </div>\r\n\r\n              {/* Content */}\r\n              <div className=\"px-[25px] py-0 space-y-4\">\r\n                {/* Grille de boutons RPE - 2 lignes de 5 */}\r\n                <div className=\"flex flex-col gap-[10px] items-center w-full\">\r\n                  {/* Premi\u00e8re ligne : 1-5 */}\r\n                  <div className=\"flex gap-[8px] items-center justify-center w-full\">\r\n                    {[1, 2, 3, 4, 5].map((rating) => (\r\n                      <button\r\n                        key={rating}\r\n                        type=\"button\"\r\n                        onClick={() => handleRpeSelect(rating)}\r\n                        className={`border rounded-full w-[36px] h-[36px] flex items-center justify-center transition-all duration-200 ${currentRpe === rating\r\n                          ? 'bg-[#d4845a] border-[#d4845a] shadow-sm'\r\n                          : 'bg-white/5 border-white/20 hover:bg-white/10 hover:border-white/30'\r\n                          }`}\r\n                      >\r\n                        <span className={`text-[15px] font-normal leading-none ${currentRpe === rating ? 'text-white' : 'text-white/75'\r\n                          }`}>\r\n                          {rating}\r\n                        </span>\r\n                      </button>\r\n                    ))}\r\n                  </div>\r\n\r\n                  {/* Deuxi\u00e8me ligne : 6-10 */}\r\n                  <div className=\"flex gap-[8px] items-center justify-center w-full\">\r\n                    {[6, 7, 8, 9, 10].map((rating) => (\r\n                      <button\r\n                        key={rating}\r\n                        type=\"button\"\r\n                        onClick={() => handleRpeSelect(rating)}\r\n                        className={`border rounded-full w-[36px] h-[36px] flex items-center justify-center transition-all duration-200 ${currentRpe === rating\r\n                          ? 'bg-[#d4845a] border-[#d4845a] shadow-sm'\r\n                          : 'bg-white/5 border-white/20 hover:bg-white/10 hover:border-white/30'\r\n                          }`}\r\n                      >\r\n                        <span className={`text-[15px] font-normal leading-none ${currentRpe === rating ? 'text-white' : 'text-white/75'\r\n                          }`}>\r\n                          {rating}\r\n                        </span>\r\n                      </button>\r\n                    ))}\r\n                  </div>\r\n                </div>\r\n              </div>\r\n\r\n              {/* Footer */}\r\n              <div className=\"flex flex-col gap-2 px-[25px] pt-[15px] pb-[20px]\">\r\n                <button\r\n                  type=\"button\"\r\n                  onClick={() => {\r\n                    setIsRpeModalOpen(false);\r\n                    setSelectedSetForRpe(null);\r\n                  }}\r\n                  className=\"flex-1 py-2 px-4 bg-[#d4845a] hover:bg-[#c47850] text-white rounded-lg font-normal text-[13px] transition-colors\"\r\n                >\r\n                  Fermer\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>,\r\n          document.body\r\n        );\r\n      })", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\ExerciseValidationModal.jsx", "source_location": "L1875"}]}