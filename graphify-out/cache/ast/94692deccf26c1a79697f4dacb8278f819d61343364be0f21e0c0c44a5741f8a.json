nd kg when it looks numeric\n                    return `${raw}${!/[a-zA-Z]/.test(raw) ? 'kg' : ''}`;\n                  }\n                  return raw;\n                })();\n                const rpeText = rpe > 0 ? `RPE ${rpe}` : null;\n\n                const parts = [seriesText];\n                if (repsText) parts.push(repsText);\n\n                if (weightText || rpeText) {\n                  return (\n                    <>\n                      {parts.join(' \u2022 ')}\n                      {weightText && (\n                        <>\n                          {' '}\n                          <span style={{ color: 'var(--kaiylo-primary-hex)', fontWeight: 400 }}>\n                            @{weightText}\n                          </span>\n                        </>\n                      )}\n                      {rpeText && (\n                        <>\n                          {' '}\n                          <span style={{ color: 'var(--kaiylo-primary-hex)', fontWeight: 400 }}>{rpeText}</span>\n                        </>\n                      )}\n                      {exerciseTempo && <> \u2022 Tempo {exerciseTempo}</>}\n                    </>\n                  );\n                }\n                const result = parts.join(' \u2022 ');\n                return (\n                  <>\n                    {result}\n                    {exerciseTempo && <> \u2022 Tempo {exerciseTempo}</>}\n                  </>\n                );\n              })", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L562"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "trim", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L714"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "slice", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L714"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "trim", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L762"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "format", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L929"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "(() => {\n                    const { weight, reps, rpe } = getVideoWeightAndReps(video);\n                    const totalSets = totalSetsProp ?? getTotalSetsForVideo(video);\n                    const seriesText = `S\u00e9rie ${video.set_number || 1}/${totalSets}`;\n                    const repsText = reps > 0 ? `${reps} reps` : null;\n                    const weightText = (() => {\n                      if (weight === null || weight === undefined || weight === '') return null;\n                      const raw = String(weight).trim();\n                      if (!raw) return null;\n                      if (raw.toLowerCase() === 'pdc') return 'PDC';\n                      const n = Number(raw);\n                      if (!Number.isNaN(n) && raw !== '') {\n                        return `${raw}${!/[a-zA-Z]/.test(raw) ? 'kg' : ''}`;\n                      }\n                      return raw;\n                    })();\n                    const rpeText = rpe > 0 ? `RPE ${rpe}` : null;\n\n                    const parts = [seriesText];\n                    if (repsText) parts.push(repsText);\n\n                    if (weightText || rpeText) {\n                      return (\n                        <>\n                          {parts.join(' \u2022 ')}\n                          {weightText && (\n                            <>\n                              {' '}\n                              <span style={{ color: 'var(--kaiylo-primary-hex)', fontWeight: 400 }}>\n                                @{weightText}\n                              </span>\n                            </>\n                          )}\n                          {rpeText && (\n                            <>\n                              {' '}\n                              <span style={{ color: 'var(--kaiylo-primary-hex)', fontWeight: 400 }}>{rpeText}</span>\n                            </>\n                          )}\n                          {exerciseTempo && <> \u2022 Tempo {exerciseTempo}</>}\n                        </>\n                      );\n                    } else {\n                      const result = parts.join(' \u2022 ');\n                      return (\n                        <>\n                          {result}\n                          {exerciseTempo && <> \u2022 Tempo {exerciseTempo}</>}\n                        </>\n                      );\n                    }\n                  })", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L957"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "trim", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L1111"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "slice", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L1111"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "trim", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L1291"}, {"caller_nid": "components_videodetailmodal_videodetailmodal", "callee": "trim", "source_file": "C:\\Users\\kheff\\Kaiylo_Project\\frontend\\src\\components\\VideoDetailModal.jsx", "source_location": "L1293"}]}